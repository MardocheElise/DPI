// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ProfessionnelSante {
  idProfessionnel     Int       @id @default(autoincrement())
  matricule           String    @unique @db.VarChar(20)
  nom                 String    @db.VarChar(100)
  prenom              String    @db.VarChar(100)
  dateNaissance       DateTime?
  specialite          String?   @db.VarChar(100)
  fonction            String?   @db.VarChar(100)
  serviceRattachement String?   @db.VarChar(100)
  email               String?   @db.VarChar(100)
  telephone           String?   @db.VarChar(20)
  carteCps            String?   @unique @db.VarChar(20)
  dateEmbauche        DateTime?
  actif               Boolean   @default(true)
  dateCreation        DateTime  @default(now())
  dateModification    DateTime  @updatedAt

  utilisateur    Utilisateur?
  chefDeServices Service[]      @relation("ChefService")
  sejours        Sejour[]
  consultations  Consultation[]

  prescriptionExamens     PrescriptionExamen[]
  prescriptionMedicaments PrescriptionMedicament[]
}

model RoleUtilisateur {
  idRole       Int      @id @default(autoincrement())
  nomRole      String   @unique @db.VarChar(50)
  description  String?
  permissions  Json?
  dateCreation DateTime @default(now())

  utilisateurs Utilisateur[]
}

model Utilisateur {
  idUtilisateur   Int       @id @default(autoincrement())
  idProfessionnel Int?      @unique
  idRole          Int
  username        String    @unique @db.VarChar(50)
  passwordHash    String    @db.VarChar(255)
  actif           Boolean   @default(true)
  lastLogin       DateTime?
  dateCreation    DateTime  @default(now())

  professionnel           ProfessionnelSante?      @relation(fields: [idProfessionnel], references: [idProfessionnel])
  role                    RoleUtilisateur          @relation(fields: [idRole], references: [idRole])
  patients                Patient[]
  sejours                 Sejour[]
  mouvementSejours        MouvementSejour[]
  consultations           Consultation[]
  prescriptionMedicaments PrescriptionMedicament[]
}

model Service {
  idService     Int     @id @default(autoincrement())
  nomService    String  @db.VarChar(100)
  typeService   String? @db.VarChar(50)
  chefServiceId Int?
  capaciteLits  Int     @default(0)
  telephone     String? @db.VarChar(20)
  email         String? @db.VarChar(100)
  actif         Boolean @default(true)

  chefService           ProfessionnelSante? @relation("ChefService", fields: [chefServiceId], references: [idProfessionnel])
  sejours               Sejour[]
  mouvementsOrigine     MouvementSejour[]   @relation("ServiceOrigine")
  mouvementsDestination MouvementSejour[]   @relation("ServiceDestination")
  consultations         Consultation[]
}

model Patient {
  idPatient Int @id @default(autoincrement())

  // Identité nationale
  ins           String @unique @db.VarChar(20)
  numeroDossier String @unique @db.VarChar(20)

  nom           String   @db.VarChar(100)
  prenom        String   @db.VarChar(100)
  nomMari       String?  @db.VarChar(100)
  dateNaissance DateTime
  lieuNaissance String?  @db.VarChar(200)
  sexe          Sexe
  nationalite   String?  @db.VarChar(50)

  // Coordonnées
  adresse   String? @db.VarChar(255)
  commune   String? @db.VarChar(100)
  ville     String? @db.VarChar(100)
  telephone String? @db.VarChar(20)
  email     String? @db.VarChar(100)

  // Situation personnelle
  situationMatrimoniale String? @db.VarChar(30)
  profession            String? @db.VarChar(100)
  employeur             String? @db.VarChar(100)

  // Médical
  groupeSanguin String? @db.VarChar(5)
  rhesus        String? @db.VarChar(2)

  // Assurance
  numeroSecuriteSociale String?  @db.VarChar(50)
  assuranceNom          String?  @db.VarChar(100)
  assuranceNumero       String?  @db.VarChar(50)
  tauxCouverture        Decimal? @db.Decimal(5, 2)

  // Urgences
  contactUrgenceNom  String? @db.VarChar(100)
  contactUrgenceTel  String? @db.VarChar(20)
  contactUrgenceLien String? @db.VarChar(50)

  contactUrgenceNom2 String? @db.VarChar(100)
  contactUrgenceTel2 String? @db.VarChar(20)

  // Médecin traitant
  medecinTraitant    String? @db.VarChar(100)
  medecinTraitantTel String? @db.VarChar(20)

  // Photo
  photoPath String? @db.VarChar(255)

  // DMP
  nonOppositionDmp Boolean @default(true)
  fichierDmp       String? @db.VarChar(50)

  // Métadonnées
  dateInscription  DateTime  @default(now())
  dateModification DateTime  @updatedAt
  dernierAccess    DateTime?

  utilisateurDernierAccess Int?
  utilisateur              Utilisateur?             @relation(fields: [utilisateurDernierAccess], references: [idUtilisateur])
  sexeIdSexe               Int
  allergies                Allergie[]
  antecedentPersonnels     AntecedentPersonnel[]
  antecedentFamilials      AntecedentFamilial[]
  sejours                  Sejour[]
  consultations            Consultation[]
  prescriptionExamens      PrescriptionExamen[]
  prescriptionMedicaments  PrescriptionMedicament[]

  @@index([nom])
  @@index([prenom])
  @@index([ins])
  @@index([numeroDossier])
  @@index([dateNaissance])
}

enum Sexe {
  M
  F
}

enum TypeAllergie {
  medicament
  aliment
  autre
}

enum SeveriteAllergie {
  legere
  moderee
  grave
  vitale
}

enum TypeAntecedent {
  maladie
  chirurgie
  hospitalisation
  grossesse
  accident
}

enum ParentFamilial {
  pere
  mere
  frere
  soeur
  enfant
  grand_parent
}

model Allergie {
  idAllergie Int @id @default(autoincrement())

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [idPatient], onDelete: Cascade)

  typeAllergie TypeAllergie
  nomAllergie  String            @db.VarChar(200)
  description  String?
  severite     SeveriteAllergie?

  dateDeclaration DateTime?
  actif           Boolean   @default(true)

  dateCreation DateTime @default(now())

  @@index([patientId])
}

model AntecedentPersonnel {
  idAntecedent Int @id @default(autoincrement())

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [idPatient], onDelete: Cascade)

  typeAntecedent TypeAntecedent
  nomAntecedent  String         @db.VarChar(200)

  dateSurvenue DateTime?
  ageSurvenue  Int?

  description      String?
  traitementActuel Boolean @default(false)
  traite           Boolean @default(true)
  actif            Boolean @default(true)

  dateCreation DateTime @default(now())

  @@index([patientId])
}

model AntecedentFamilial {
  idAntecedentFam Int @id @default(autoincrement())

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [idPatient], onDelete: Cascade)

  parent      ParentFamilial?
  typeMaladie String          @db.VarChar(100)
  nomMaladie  String?         @db.VarChar(200)
  description String?

  actif        Boolean  @default(true)
  dateCreation DateTime @default(now())

  @@index([patientId])
}

enum TypeHospitalisation {
  complete
  jour
  urgence
  ambulatory
}

enum StatutSejour {
  en_cours
  termine
  annule
  deces
}

enum ModeSortie {
  gueri
  ameliore
  stable
  aggrave
  deces
  contre_avis
}

enum TypeMouvement {
  transfer_service
  transfer_lit
  permission
  absence
}

model Sejour {
  idSejour Int @id @default(autoincrement())

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [idPatient])

  numeroSejour String @unique @db.VarChar(20)

  serviceId Int?
  service   Service? @relation(fields: [serviceId], references: [idService])

  idLit Int?

  typeHospitalisation TypeHospitalisation

  dateAdmissionPrevue DateTime?
  dateAdmissionReelle DateTime?
  dateSortiePrevue    DateTime?
  dateSortieReelle    DateTime?

  medecinResponsableId Int?
  medecinResponsable   ProfessionnelSante? @relation(fields: [medecinResponsableId], references: [idProfessionnel])

  motifAdmission      String?
  diagnosticPrincipal String? @db.VarChar(200)
  diagnosticCim10     String? @db.VarChar(20)

  statut     StatutSejour @default(en_cours)
  modeSortie ModeSortie?

  contreVisite Boolean @default(false)

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  utilisateurCreationId Int?
  utilisateurCreation   Utilisateur? @relation(fields: [utilisateurCreationId], references: [idUtilisateur])

  mouvements              MouvementSejour[]
  consultations           Consultation[]
  prescriptionExamens     PrescriptionExamen[]
  prescriptionMedicaments PrescriptionMedicament[]

  @@index([patientId])
  @@index([statut])
}

model MouvementSejour {
  idMouvement Int @id @default(autoincrement())

  sejourId Int
  sejour   Sejour @relation(fields: [sejourId], references: [idSejour], onDelete: Cascade)

  typeMouvement TypeMouvement

  serviceOrigineId Int?
  serviceOrigine   Service? @relation("ServiceOrigine", fields: [serviceOrigineId], references: [idService])

  serviceDestinationId Int?
  serviceDestination   Service? @relation("ServiceDestination", fields: [serviceDestinationId], references: [idService])

  litOrigine     Int?
  litDestination Int?

  dateMouvement DateTime @default(now())
  motif         String?

  utilisateurId Int?
  utilisateur   Utilisateur? @relation(fields: [utilisateurId], references: [idUtilisateur])
}

enum TypeConsultation {
  initiale
  suivi
  urgence
  specialiste
  reconsultation
}

enum TypeMotif {
  douleur
  fievre
  controles
  urgence
}

enum NiveauUrgence {
  vert
  orange
  rouge
}

enum Conscience {
  claire
  alteree
  obnubilee
  coma
}

enum UniteMedicament {
  mg
  ml
  g
  UI
}

enum VoieAdministration {
  orale
  intraveineuse
  intramusculaire
  sous_cutanee
}

enum Frequence {
  une_fois_jour
  deux_fois_jour
  trois_fois_jour
  toutes_8h
  autre
}

enum StatutPrescription {
  prescrit
  dispense
  administre
  annule
}

enum Priorite {
  normale
  urgente
  tres_urgente
}

enum TypeExamen {
  biologie
  imagerie
  ecg
  autre
}

enum CategorieExamen {
  sang
  urine
  radiographie
  scanner
  irm
  echographie
}

enum StatutExamen {
  prescrit
  en_cours
  realise
  resultats_disponibles
  annule
}

model Consultation {
  idConsultation Int @id @default(autoincrement())

  sejourId Int?
  sejour   Sejour? @relation(fields: [sejourId], references: [idSejour])

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [idPatient])

  medecinId Int
  medecin   ProfessionnelSante @relation(fields: [medecinId], references: [idProfessionnel])

  typeConsultation TypeConsultation

  serviceConsultationId Int?
  serviceConsultation   Service? @relation(fields: [serviceConsultationId], references: [idService])

  dateConsultation DateTime @default(now())

  motifConsultation String
  typeMotif         TypeMotif?

  tensionArterielle     String?
  frequenceCardiaque    Int?
  frequenceRespiratoire Int?
  temperature           Decimal? @db.Decimal(4, 2)
  saturationO2          Int?
  poids                 Decimal? @db.Decimal(5, 2)
  taille                Decimal? @db.Decimal(5, 2)
  imc                   Decimal? @db.Decimal(5, 2)

  douleurEva Int?
  conscience Conscience?

  anamnese       String?
  examenPhysique String?

  diagnosticPrincipal    String?
  diagnosticCim10        String?
  diagnosticAssocie      String?
  diagnosticDifferentiel String?

  niveauUrgence NiveauUrgence?

  planSoins       String?
  recommandations String?

  valide         Boolean   @default(false)
  dateValidation DateTime?
  validateurId   Int?

  dateCreation          DateTime     @default(now())
  utilisateurCreationId Int?
  utilisateurCreation   Utilisateur? @relation(fields: [utilisateurCreationId], references: [idUtilisateur])

  prescriptionsMedicaments PrescriptionMedicament[]
  prescriptionsExamens     PrescriptionExamen[]

  @@index([patientId])
  @@index([sejourId])
}

model PrescriptionExamen {
  idPrescriptionExamen Int @id @default(autoincrement())

  consultationId Int?
  consultation   Consultation? @relation(fields: [consultationId], references: [idConsultation])

  sejourId Int?
  sejour   Sejour? @relation(fields: [sejourId], references: [idSejour])

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [idPatient])

  medecinId Int
  medecin   ProfessionnelSante @relation(fields: [medecinId], references: [idProfessionnel])

  typeExamen      TypeExamen
  categorieExamen CategorieExamen
  nomExamen       String
}

model PrescriptionMedicament {
  idPrescription Int @id @default(autoincrement())

  consultationId Int?
  consultation   Consultation? @relation(fields: [consultationId], references: [idConsultation])

  sejourId Int?
  sejour   Sejour? @relation(fields: [sejourId], references: [idSejour])

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [idPatient])

  medecinId Int
  medecin   ProfessionnelSante @relation(fields: [medecinId], references: [idProfessionnel])

  idMedicament Int?

  nomMedicament String  @db.VarChar(200)
  dci           String?

  dose               String
  unite              UniteMedicament
  voieAdministration VoieAdministration
  frequence          Frequence
  duree              Int?
  dureeUnite         String?

  dateDebut DateTime  @default(now())
  dateFin   DateTime?

  idProtocole  Int?
  protocoleNom String?

  urgente  Boolean   @default(false)
  priorite Priorite?

  valide         Boolean   @default(false)
  dateValidation DateTime?
  validateurId   Int?

  validationPharmacie Boolean @default(false)

  alerteInteractions     Json?
  alerteContreIndication Boolean @default(false)

  statut StatutPrescription @default(prescrit)

  dateCreation          DateTime     @default(now())
  utilisateurCreationId Int?
  utilisateurCreation   Utilisateur? @relation(fields: [utilisateurCreationId], references: [idUtilisateur])

  @@index([patientId])
}
